  kprobe:ip6_forward
  {
      $skb = (struct sk_buff *)arg0;
      $ip6 = (struct ipv6hdr *)($skb->head + $skb->network_header);

      if ($ip6->nexthdr == 6 || $ip6->nexthdr == 17) {
          $th = (struct tcphdr *)((uint8 *)$ip6 + 40);
          $dport = bswap($th->dest);
	  $sport = swap($th->source);

          if ($dport == 5201 || $source == 5201) {
              printf("cpu=%u src_port=%u dst_port=%u\n", cpu,
		      $sport, $dport);
          }
      }
  }
